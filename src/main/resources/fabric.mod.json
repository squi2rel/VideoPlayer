{
	"schemaVersion": 1,
	"id": "videoplayer",
	"version": "${version}",
	"name": "VideoPlayer",
	"description": "Player video in-game using MPV/VLC library",
	"authors": [
		"squi2rel",
		"cloudfl4re"
	],
	"contact": {
		"sources": "https://github.com/squi2rel/VideoPlayer"
	},
	"license": "GPL-3.0",
	"icon": "assets/videoplayer/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
          "com.github.squi2rel.vp.VideoPlayerMain"
		],
		"client": [
			"com.github.squi2rel.vp.VideoPlayerClient"
		],
		"modmenu": [
			"com.github.squi2rel.vp.VideoPlayerModMenu"
		]
	},
	"mixins": [
		"videoplayer.mixins.json",
		{
			"config": "videoplayer.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.17.3",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	},
	"suggests": {
		"modmenu": "*"
	}
}
